{
  "manifest_version": 3,
  "name": "AI Text Simplifier",
  "version": "2.1",
  "permissions": [
    "contextMenus",
    "activeTab",
    "tts",
    "storage"
  ],
  "host_permissions": [
    "https://apikey-wxbq.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}